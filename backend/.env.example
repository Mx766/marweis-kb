# ── App ─────────────────────────────────────────────────
ENVIRONMENT=development

# ── Database ───────────────────────────────────────────
DB_USER=marweis
DB_PASSWORD=marweis_dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marweis_kb
# DATABASE_URL is auto-built from the above — you can override it:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ── JWT ────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-random-string
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_HOURS=8

# ── Meilisearch ────────────────────────────────────────
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=marweis_dev_key

# ── MinIO ──────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=marweis-documents
# MINIO_SECURE=false

# ── Gotenberg ──────────────────────────────────────────
GOTENBERG_URL=http://localhost:3000
